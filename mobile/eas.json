{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:3000/api/v1",
        "EXPO_PUBLIC_WS_URL": "http://localhost:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://staging-api.nebschoolerp.com/api/v1",
        "EXPO_PUBLIC_WS_URL": "https://staging-api.nebschoolerp.com"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.nebschoolerp.com/api/v1",
        "EXPO_PUBLIC_WS_URL": "https://api.nebschoolerp.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
